generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String        @id
  email        String?
  monthBudget  Float         @default(1500)
  apiToken     String?       @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
  recurring    Recurring[]
  parseRules   ParseRule[]
  pendingSms   PendingSms[]
}

model Transaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  sub       String
  note      String?
  cat       String
  amount    Float
  date      DateTime
  smsHash   String?
  createdAt DateTime @default(now())

  @@unique([userId, smsHash])
  @@index([userId, date])
}

model Recurring {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String
  title      String
  sub        String
  note       String?
  cat        String
  amount     Float
  dayOfMonth Int
  active     Boolean  @default(true)
  startYm    String
  lastRunYm  String?
  createdAt  DateTime @default(now())

  @@index([userId, active])
}

model ParseRule {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  senderPattern   String?
  contentPattern  String?
  amountRegex     String
  merchantRegex   String
  currencyRegex   String?
  type            String
  defaultCategory String
  currency        String   @default("USD")
  priority        Int      @default(0)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, active, priority])
}

model PendingSms {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  raw        String
  receivedAt DateTime
  smsHash    String
  createdAt  DateTime @default(now())

  @@unique([userId, smsHash])
  @@index([userId, createdAt])
}
